# ─────────────────────────────────────────────────────────────────────────────
# Carbon Tracker Backend — Environment Variables
# Copy this file to .env and fill in real values.
# .env is listed in .dockerignore and .gitignore — NEVER commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Redis ─────────────────────────────────────────────────────────
# docker-compose overrides this to redis://redis:6379 automatically.
# Keep localhost here for local (non-Docker) development.
REDIS_URL=redis://localhost:6379

# ── Model paths (relative to /app inside the container) ───────────
MODEL_DIR=models
DATA_DIR=data
CATBOOST_MODEL_PATH=models/catboost_best.cbm
HYBRID_MODEL_PATH=models/hybrid_graphsage_catboost_best.cbm
TFT_CKPT_PATH=models/tft_best-82-0.1107.ckpt
EMBEDDINGS_PATH=models/city_embeddings_1.npy

# ── Cache TTLs (seconds) ──────────────────────────────────────────
CACHE_TTL_PREDICT=300
CACHE_TTL_STATIC=3600

# ── Inference tuning ─────────────────────────────────────────────
LOW_CONFIDENCE_THRESHOLD_KG=1000.0
VIRTUAL_ENSEMBLE_COUNT=10
